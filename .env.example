# SkillHub Environment Configuration

# ───────── Server Settings ─────────
PORT=5000
NODE_ENV=development
APP_BASE_URL=http://localhost:5000
CORS_ORIGIN=http://localhost:3000

# ───────── Database & Storage ─────────
MONGO_URI=mongodb://localhost:27017/skillhub
REDIS_URL=redis://127.0.0.1:6379

# ───────── Security ─────────
# ✅ Required for token generation and validation
JWT_SECRET=your_super_secret_jwt_key_here
# RATE_LIMIT_USER_KEY_STRATEGY=auth-only

# ───────── Chapa Payment Gateway ─────────
# ✅ Required for processing payments
CHAPA_SECRET_KEY=CHASECK_TEST-xxxxxxxxxxxxxxxxxxxx
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-xxxxxxxxxxxxxxxxxxxx
CHAPA_WEBHOOK_SECRET=your_chapa_webhook_secret_here
CHAPA_BASE_URL=https://api.chapa.co

# ───────── Rate Limiting (Optional Overrides) ─────────
RATE_LIMIT_POINTS=100
RATE_LIMIT_DURATION=60
# RATE_LIMIT_EXEMPT=/health,/static
# RATE_LIMIT_ROUTES=/api/auth/login:10/60;/api/auth/register:5/60
# RATE_LIMIT_ROLE_QUOTAS=free:50/60;pro:1000/60;admin:unlimited
